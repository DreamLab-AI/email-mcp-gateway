# Private Email MCP Gateway — configuration template.
# Copy to `.env` (gitignored) and fill in. Generate tokens with: openssl rand -hex 32
#
#   cp env.template .env
#
# docker-compose.yml reads these via ${VAR} substitution. Everything has a safe default in
# gateway/src/config.py EXCEPT the secrets below, which you MUST set.

# ── Secrets (required) ───────────────────────────────────────────────────────
# Bearer token the MCP client must present (Authorization: Bearer <token>).
MCP_BEARER_TOKEN=
# Salt for opaque ref_id hashing. Rotating it invalidates all previously issued refs.
REF_SALT=

# ── Proton Mail Bridge (set AFTER `docker exec -it email-mcp-gateway protonctl login`) ──
# From `protonctl info`: the Bridge IMAP username (your Proton address) and generated password.
IMAP_USER=
IMAP_PASS=

# ── External services (override the placeholders with your real hosts) ───────
# Embeddings: xinference (OpenAI-compatible) serving bge-m3.
XINFERENCE_BASE_URL=http://xinference.local:9997/v1
EMBED_MODEL=bge-m3
EMBED_DIM=1024
# Local email-intelligence model (abliterated Qwen via llama.cpp).
QWEN_BASE_URL=http://host.docker.internal:8080/v1
QWEN_MODEL=APEX-Q5_K_M.gguf

# ── Optional tuning (defaults in config.py are usually fine) ─────────────────
# MCP_BIND=0.0.0.0:8765
# TOP_K=8
# SAFEGUARD_GGUF=/models/gpt-oss-safeguard-20b-MXFP4.gguf
# PROTON_BRIDGE_ENABLED=1
# IMAP_EXCLUDE=Trash,Spam,All Mail
